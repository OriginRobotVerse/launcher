{
  "name": "originrobot",
  "version": "0.6.8",
  "description": "Origin — CLI tool for managing robots, installing apps, and serving a dashboard",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "origin": "dist/cli.js"
  },
  "files": [
    "dist",
    "dashboard/out",
    "scripts/postinstall.cjs",
    "simulators",
    "schemas"
  ],
  "scripts": {
    "build": "tsc && node -e \"const fs=require('fs'); const p='dist/cli.js'; const c=fs.readFileSync(p,'utf8'); if(!c.startsWith('#!')) fs.writeFileSync(p,'#!/usr/bin/env node\\n'+c);\"",
    "build:dashboard": "cd dashboard && pnpm install && pnpm build",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "cli": "tsx src/cli.ts",
    "postinstall": "node scripts/postinstall.cjs",
    "prepublishOnly": "pnpm build:dashboard && pnpm build"
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "serialport": "^12.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/OriginRobotVerse/launcher"
  },
  "keywords": [
    "robotics",
    "mujoco",
    "simulation",
    "hardware",
    "arduino",
    "cli",
    "dashboard"
  ]
}
